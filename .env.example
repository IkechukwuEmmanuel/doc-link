# SpacePad backend environment. Copy to .env and adjust. NEVER commit .env.

# --- Database (Supabase) ---
# App runtime → Supabase TRANSACTION-mode pooler (port 6543). Prepared statements
# are disabled in app/db/session.py for pgbouncer compatibility. Username is
# project-qualified: postgres.<project-ref>.
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Migrations → a NON-transaction-pooled connection (Alembic needs session-level
# features transaction pooling breaks). Prefer Supabase's direct host
# (db.<project-ref>.supabase.co:5432); where that host is IPv6-only and your
# network is IPv4-only, use the SESSION-mode pooler (port 5432), the IPv4
# equivalent. Falls back to DATABASE_URL when unset.
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Redis (rate limiting + presence; used from Phase 2/6) ---
REDIS_URL=redis://localhost:6379/0

# --- App ---
ENVIRONMENT=development
# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:5173

# --- Object storage (S3-compatible; used from Phase 3) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=spacepad
S3_SECRET_KEY=spacepadsecret
S3_BUCKET=spacepad-uploads

# --- Malware scanning (Phase 3) ---
# Fails closed: when disabled/unreachable, uploads are marked failed and never served.
# Enable ClamAV with: docker compose --profile scan up -d clamav
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# --- Auth (Supabase Auth / gotrue) ---
# FastAPI calls Supabase Auth for signup/login/refresh/reset and verifies the
# ES256 user tokens it issues against the project JWKS. anon key = public `apikey`
# header; service-role key = admin ops (keep secret, server-only).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Audience claim expected on Supabase access tokens (default for gotrue).
SUPABASE_JWT_AUD=authenticated
# Legacy HS256 self-minting secret — retained only so the test harness can forge
# tokens offline. Not used against Supabase in production.
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
# Google OAuth is configured in the Supabase dashboard (Auth → Providers), not
# here. These remain only for the legacy direct-Google path if ever re-enabled.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Where emailed links point (reset/verify) and where Google redirects back to.
FRONTEND_BASE_URL=http://localhost:5173

# --- Rate limiting (Phase 6) ---
# Enforced via Redis when reachable; fails OPEN otherwise (best-effort abuse
# prevention, not a security control). Run Redis and confirm at launch.
RATE_LIMIT_ENABLED=true
IP_HASH_SALT=change-me-in-production
RL_CREATE_PER_HOUR=10
RL_CREATE_BURST_SECONDS=5
RL_EDIT_PER_MIN=60

# --- Cold storage flagging (Phase 6) ---
# Storage-cost marker only — NOT deletion, NOT user-facing expiry.
COLD_STORAGE_AFTER_DAYS=365

# --- Email delivery (Phase 7) ---
# Empty => transactional emails are LOGGED, not sent (stub-and-flag, like ClamAV).
# Set a provider and implement send_email() before launch. SMTP is the boring choice.
EMAIL_PROVIDER=
EMAIL_FROM=no-reply@spacepad.app
PASSWORD_RESET_TTL_SECONDS=3600

# --- Upload caps (configurable, not magic numbers) ---
ANON_MAX_FILES_PER_PAD=5
ANON_MAX_FILE_BYTES=10485760
ANON_MAX_TOTAL_BYTES=26214400
AUTH_MAX_FILES_PER_PAD=50
AUTH_MAX_FILE_BYTES=52428800
AUTH_MAX_TOTAL_BYTES=524288000
